# RoadshowOps Backend - Environment Configuration
# Copy to .env and adjust for your local on-prem environment.

# HTTP
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# CORS (comma-separated list of allowed frontend origins)
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (local / on-prem only)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/roadshowops

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=12h
BCRYPT_COST=10

# Offline payment processing
WECHAT_IMPORT_DIR=./wechat_imports
WECHAT_SHARED_SECRET=change-me-use-a-long-random-hex
PAYMENT_RETRY_MAX=3
PAYMENT_RETRY_INTERVAL_MINUTES=5

# Data ingestion (offline)
INGESTION_ROOT_DIR=./ingestion_inbox
INGESTION_SCHEDULER_INTERVAL_MINUTES=5

# Security
# FIELD_ENCRYPTION_KEY must decode to 32 bytes for AES-256.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=replace-me-with-base64-32-byte-key
PASSWORD_MIN_LENGTH=12
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
